# Louder Configuration
# =======================
# This file configures the prompt rewriting logic and downstream models.
# The default configuration below serves as an example.
#
# Copy this file to louder.yaml to get started.

# Downstream providers configuration
providers:
  - type: openai
    key: "sk-proj-your-openai-key"
    url: "https://api.openai.com/v1"
  - type: anthropic
    key: "sk-ant-your-anthropic-key"
    url: "https://api.anthropic.com/v1"

# Prompt rewriting configuration
rewrite_model: "gpt-4o-mini"
rewrite_url: "https://api.openai.com/v1"
rewrite_key: "sk-proj-your-openai-key"
intensity: 8
auto_tune: false

