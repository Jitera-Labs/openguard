    <div class="crt-noise"></div>
    <div class="crt-grille"></div>
    <div class="scanlines"></div>
    <div class="vignette"></div>

    <script is:inline>
        const canvas = document.getElementById('bg-canvas');
        const ctx = canvas.getContext('2d');

        let width, height;

        function resize() {
            const newWidth = window.innerWidth;
            const newHeight = window.innerHeight;

            if (width !== newWidth) {
                width = canvas.width = newWidth;
                height = canvas.height = newHeight;
            } else if (Math.abs(height - newHeight) > 100) {
                 width = canvas.width = newWidth;
                 height = canvas.height = newHeight;
            }
        }

        window.addEventListener('resize', resize);
        width = canvas.width = window.innerWidth;
        height = canvas.height = window.innerHeight;

        const gridSize = 40;
        let offset = 0;
        const speed = 0.5;

        const stars = [];
        const numStars = 70;

        function smoothstep(edge0, edge1, x) {
            const t = Math.max(0, Math.min(1, (x - edge0) / (edge1 - edge0)));
            return t * t * (3 - 2 * t);
        }

        function initStar(startRandom) {
            const isRed = Math.random() > 0.8;
            // Power distribution: mostly small, some medium, few large (4–50px base at full depth)
            const r = Math.random();
            const baseSize = 4 + Math.pow(r, 3) * 46;
            // lane: inverse-normal — most particles stream along the sides, few in center
            const dist = Math.pow(Math.random(), 0.4);
            const side = Math.random() < 0.5 ? -1 : 1;
            const lane = 0.5 + side * dist;
            return {
                z: startRandom ? Math.random() : 0,
                lane: lane,
                baseSize: baseSize,
                speed: 0.04 + Math.random() * 0.06,
                color: isRed ? '#ef5350' : '#66bb6a'
            };
        }

        for(let i=0; i<numStars; i++) {
            stars.push(initStar(true));
        }

        function drawGrid(dt) {
            const timeScale = (dt || 0.016) * 60;

            ctx.strokeStyle = '#333';
            ctx.lineWidth = 1;

            const horizon = height * 0.3;
            const fov = 300;

            ctx.fillStyle = '#0a0a0a';
            ctx.fillRect(0, 0, width, height);

            const vpX = width / 2;
            const vpY = height * 0.2;
            const bottomWidth = width * 4;

            stars.forEach((star, idx) => {
                // Advance depth along the grid
                star.z += star.speed * (dt || 0.016);
                if (star.z > 1) {
                    const newStar = initStar(false);
                    stars[idx] = newStar;
                    return;
                }

                // Perspective: t = z² matches the horizontal grid line spacing
                const t = star.z * star.z;

                // Bottom-edge x for this lane
                const xBottom = star.lane * bottomWidth - (bottomWidth - width) / 2;

                // Interpolate along the radial line from vanishing point to bottom edge
                const sx = vpX + (xBottom - vpX) * t;
                const sy = vpY + (height - vpY) * t;

                // Linear perspective scaling — size proportional to z for correct depth
                const size = star.baseSize * Math.max(0.02, star.z);

                // Smooth fade in from vanishing point, smooth fade out at grid bottom
                const fadeIn = smoothstep(0, 0.12, star.z);
                const fadeOut = 1 - smoothstep(0.88, 1.0, star.z);
                ctx.globalAlpha = fadeIn * fadeOut;

                // Diamond data packet — matches flow visualization
                ctx.fillStyle = star.color;
                ctx.beginPath();
                ctx.moveTo(sx, sy - size);
                ctx.lineTo(sx + size, sy);
                ctx.lineTo(sx, sy + size);
                ctx.lineTo(sx - size, sy);
                ctx.fill();
            });
            ctx.globalAlpha = 1;

            ctx.beginPath();

            const centerX = width / 2;

            for (let x = -width; x < width * 2; x += gridSize) {
                ctx.moveTo(x, height);
                const spacing = 40;
            }

            offset = (offset + speed * timeScale) % gridSize;

            for (let z = 0; z < height; z += gridSize) {
            }

            const vanishingPointY = vpY;
            const vanishingPointX = vpX;

            const numLines = 40;

            for(let i = 0; i <= numLines; i++) {
                const xBottom = (i / numLines) * bottomWidth - (bottomWidth - width)/2;
                ctx.moveTo(vanishingPointX, vanishingPointY);
                ctx.lineTo(xBottom, height);
            }

            const time = Date.now() / 1000;
            const gridSpeed = 0.4;
            const gridOffset = (time * gridSpeed) % 1;

            for(let i = 0; i < 20; i++) {
                let z = (i + gridOffset) / 20;
                let y = vanishingPointY + (height - vanishingPointY) * Math.pow(z, 2);

                if (y > height) continue;
                if (y < vanishingPointY) continue;

                ctx.moveTo(0, y);
                ctx.lineTo(width, y);
            }

            ctx.strokeStyle = 'rgba(237, 237, 237, 0.3)';
            ctx.stroke();

            // Smooth gradient fade above vanishing point (no hard clip)
            ctx.fillStyle = '#0a0a0a';
            ctx.fillRect(0, 0, width, Math.max(0, vanishingPointY - 30));
            const topFade = ctx.createLinearGradient(0, vanishingPointY - 30, 0, vanishingPointY + 60);
            topFade.addColorStop(0, 'rgba(10,10,10,1)');
            topFade.addColorStop(1, 'rgba(10,10,10,0)');
            ctx.fillStyle = topFade;
            ctx.fillRect(0, Math.max(0, vanishingPointY - 30), width, 90);
        }

        let lastTime = 0;
        function animate(timestamp) {
            if (!lastTime) lastTime = timestamp;
            const dt = (timestamp - lastTime) / 1000;
            lastTime = timestamp;

            drawGrid(dt);
            requestAnimationFrame(animate);
        }

        requestAnimationFrame(animate);

        let isGuardEnabled = true;

        function toggleGuard() {
            isGuardEnabled = !isGuardEnabled;
            const container = document.querySelector('.toggle-container');
            const status = document.getElementById('guard-status');

            if (isGuardEnabled) {
                container.classList.add('active');
                status.innerText = 'ENABLED';
                status.style.color = '#fff';
            } else {
                container.classList.remove('active');
                status.innerText = 'DISABLED';
                status.style.color = '#666';
            }
        }

        document.getElementById('toggle-container').addEventListener('click', toggleGuard);
        document.querySelector('.toggle-container').classList.add('active');

        const runTabDescs = {
            launch: 'Starts OpenGuard + your coding agent in one command.',
            serve: 'Runs OpenGuard as a standalone proxy. Point your SDK at it.',
            docker: 'Containerized — no Python needed. Pass keys with -e.'
        };
        document.querySelectorAll('.run-tab').forEach(tab => {
            tab.addEventListener('click', function() {
                const target = this.dataset.tab;
                document.querySelectorAll('.run-tab').forEach(t => t.classList.toggle('active', t === this));
                document.querySelectorAll('.run-methods').forEach(m => m.style.display = m.id === 'run-methods-' + target ? 'flex' : 'none');
                document.getElementById('run-tab-desc').textContent = runTabDescs[target];
            });
        });

        document.querySelectorAll('.run-method').forEach(el => {
            el.addEventListener('click', function() {
                const cmd = this.dataset.cmd;
                navigator.clipboard.writeText(cmd);
                this.classList.add('copied');
                const copyEl = this.querySelector('.run-method-copy');
                copyEl.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>';
                setTimeout(() => {
                    this.classList.remove('copied');
                    copyEl.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>';
                }, 1500);
            });
        });

        function startFlowAnimation() {
            const flowCanvas = document.getElementById('flow-canvas');
            if (!flowCanvas) return;
            const flowCtx = flowCanvas.getContext('2d');

            let w, h;
            let particles = [];
            let effects = [];
            const eyeState = {
                offsetX: 0,
                offsetY: 0,
                targetX: 0,
                targetY: 0,
                nextTargetAt: 0,
                nextBlinkAt: 0,
                blinkStart: -1,
                blinkEnd: -1
            };

            let lastTime = 0;
            let spawnTimer = 0;
            let nextSpawnTime = 0.5;

            function resizeFlow() {
                const rect = flowCanvas.parentElement.getBoundingClientRect();
                w = flowCanvas.width = rect.width;
                h = flowCanvas.height = rect.height;
            }
            window.addEventListener('resize', resizeFlow);
            resizeFlow();

            function drawBox(x, y, width, height, label, color) {
                flowCtx.strokeStyle = color;
                flowCtx.lineWidth = 2;
                flowCtx.strokeRect(x - width/2, y - height/2, width, height);

                flowCtx.fillStyle = color;
                flowCtx.font = '12px "Geist Mono", monospace';
                flowCtx.textAlign = 'center';
                flowCtx.textBaseline = 'middle';
                flowCtx.fillText(label, x, y);
            }

            function drawEye(x, y, radius, isOpen) {
                if (!isOpen) {
                    flowCtx.strokeStyle = '#333';
                    flowCtx.lineWidth = 1;
                    flowCtx.beginPath();
                    flowCtx.moveTo(x - radius, y);
                    flowCtx.lineTo(x + radius, y);
                    flowCtx.stroke();
                    return;
                }

                flowCtx.save();
                flowCtx.translate(x, y);

                flowCtx.strokeStyle = '#fff';
                flowCtx.lineWidth = 2;
                flowCtx.beginPath();
                flowCtx.moveTo(-radius, 0);
                flowCtx.quadraticCurveTo(0, -radius*0.7, radius, 0);
                flowCtx.quadraticCurveTo(0, radius*0.7, -radius, 0);
                flowCtx.stroke();

                const time = Date.now() / 1000;

                if (time >= eyeState.nextTargetAt) {
                    eyeState.targetX = (Math.random() * 2 - 1) * (radius * 0.35);
                    eyeState.targetY = (Math.random() * 2 - 1) * (radius * 0.18);
                    eyeState.nextTargetAt = time + 0.15 + Math.random() * 0.85;
                }

                eyeState.offsetX += (eyeState.targetX - eyeState.offsetX) * 0.22;
                eyeState.offsetY += (eyeState.targetY - eyeState.offsetY) * 0.22;

                eyeState.offsetX += (Math.random() - 0.5) * radius * 0.01;
                eyeState.offsetY += (Math.random() - 0.5) * radius * 0.006;

                eyeState.offsetX = Math.max(-radius * 0.42, Math.min(radius * 0.42, eyeState.offsetX));
                eyeState.offsetY = Math.max(-radius * 0.25, Math.min(radius * 0.25, eyeState.offsetY));

                if (eyeState.nextBlinkAt === 0) {
                    eyeState.nextBlinkAt = time + 1.2 + Math.random() * 1.8;
                }

                if (time >= eyeState.nextBlinkAt && time > eyeState.blinkEnd) {
                    const blinkDuration = 0.11 + Math.random() * 0.08;
                    eyeState.blinkStart = time;
                    eyeState.blinkEnd = time + blinkDuration;
                    eyeState.nextBlinkAt = eyeState.blinkEnd + 1.2 + Math.random() * 2.8;
                }

                let openness = 1;
                if (time >= eyeState.blinkStart && time <= eyeState.blinkEnd) {
                    const t = (time - eyeState.blinkStart) / (eyeState.blinkEnd - eyeState.blinkStart);
                    if (t < 0.5) {
                        openness = 1 - (t * 2 * 0.92);
                    } else {
                        openness = 0.08 + ((t - 0.5) * 2 * 0.92);
                    }
                }

                flowCtx.fillStyle = '#fff';
                flowCtx.beginPath();
                flowCtx.save();
                flowCtx.translate(eyeState.offsetX, eyeState.offsetY);
                flowCtx.scale(1, openness);
                flowCtx.arc(0, 0, radius * 0.25, 0, Math.PI * 2);
                flowCtx.fill();

                flowCtx.shadowBlur = 10;
                flowCtx.shadowColor = '#fff';
                flowCtx.fill();
                flowCtx.shadowBlur = 0;
                flowCtx.restore();

                flowCtx.restore();
            }

            function update(timestamp) {
                if (!lastTime) lastTime = timestamp;
                const dt = (timestamp - lastTime) / 1000;
                lastTime = timestamp;

                flowCtx.clearRect(0, 0, w, h);

                const cy = h / 2;
                const cw = Math.max(40, Math.min(60, w * 0.08));

                const margin = w * 0.1;
                const availableWidth = w - (margin * 2);

                const xLLM = margin;
                const xGuard = margin + (availableWidth * 0.33);
                const xHarness = margin + (availableWidth * 0.66);
                const xEnv = w - margin;

                const travelDist = xEnv - xLLM;
                const refSpeed = travelDist / 1.0;

                const llmSpacing = cw * 1.5;
                const llmYs = [cy - llmSpacing, cy, cy + llmSpacing];

                flowCtx.strokeStyle = '#333';
                flowCtx.lineWidth = 2;
                flowCtx.setLineDash([5, 5]);

                flowCtx.beginPath();
                flowCtx.moveTo(xEnv, cy);
                flowCtx.lineTo(xHarness, cy);
                flowCtx.stroke();

                flowCtx.beginPath();
                flowCtx.moveTo(xHarness, cy);
                flowCtx.lineTo(xGuard, cy);
                flowCtx.stroke();

                llmYs.forEach(y => {
                    flowCtx.beginPath();
                    flowCtx.moveTo(xGuard, cy);
                    flowCtx.lineTo(xLLM, y);
                    flowCtx.stroke();
                });

                flowCtx.setLineDash([]);

                function drawBottomLabel(x, text) {
                    flowCtx.fillStyle = '#666';
                    flowCtx.font = '10px "Geist Mono", monospace';
                    flowCtx.textAlign = 'center';
                    flowCtx.textBaseline = 'bottom';
                    flowCtx.fillText(text, x, h - 10);
                }

                drawBottomLabel(xLLM, 'LLMs');
                drawBottomLabel(xGuard, 'PROXY');
                drawBottomLabel(xHarness, 'APP');
                drawBottomLabel(xEnv, 'ENV');

                drawBox(xEnv, cy, cw, cw, 'ENV', '#888');

                drawBox(xHarness, cy, cw, cw, 'APP', '#888');

                llmYs.forEach((y, i) => {
                     drawBox(xLLM, y, cw, cw, `LLM ${i+1}`, '#fff');
                });

                flowCtx.fillStyle = '#0a0a0a';
                flowCtx.beginPath();
                flowCtx.arc(xGuard, cy, cw/2, 0, Math.PI*2);
                flowCtx.fill();

                if (!isGuardEnabled) {
                    flowCtx.strokeStyle = '#333';
                    flowCtx.lineWidth = 2;
                    flowCtx.setLineDash([5, 5]);
                    flowCtx.beginPath();
                    flowCtx.moveTo(xGuard - cw / 2, cy);
                    flowCtx.lineTo(xGuard + cw / 2, cy);
                    flowCtx.stroke();
                    flowCtx.setLineDash([]);
                }

                drawEye(xGuard, cy, cw/2 - 5, isGuardEnabled);

                if (!isGuardEnabled) {
                    flowCtx.strokeStyle = '#333';
                    flowCtx.lineWidth = 2;
                    flowCtx.setLineDash([5, 5]);
                    llmYs.forEach(y => {
                        flowCtx.beginPath();
                        flowCtx.moveTo(xGuard, cy);
                        flowCtx.lineTo(xLLM, y);
                        flowCtx.stroke();
                    });
                    flowCtx.setLineDash([]);
                }

                spawnTimer += dt;

                if (spawnTimer > nextSpawnTime) {
                    spawnTimer = 0;

                    if (Math.random() < 0.3) {
                        nextSpawnTime = 0.1;
                    } else {
                        nextSpawnTime = 0.2 + Math.random() * 0.6;
                    }

                    const isPoison = Math.random() < 0.35;

                    particles.push({
                        id: Math.random(),
                        x: xEnv,
                        y: cy,
                        type: 'request',
                        payload: isPoison ? 'poison' : 'clean',
                        color: isPoison ? '#f00' : '#4f4',
                        size: 6,
                        vx: -refSpeed,
                        vy: 0,
                        targetLLMIndex: -1,
                        state: 'alive'
                    });
                }

                particles.forEach(p => {
                    if (p.state === 'dead') return;

                    p.x += p.vx * dt;
                    p.y += p.vy * dt;

                    if (p.vx < 0) {

                        if (Math.abs(p.x - xGuard) < 10 && p.targetLLMIndex === -1) {
                            p.x = xGuard;
                            p.y = cy;

                            let blocked = false;

                            if (isGuardEnabled && p.payload === 'poison') {
                                if (Math.random() < 0.5) {
                                    p.state = 'dead';
                                    blocked = true;
                                    effects.push({
                                        type: 'BLOCK',
                                        x: xGuard,
                                        y: cy,
                                        life: 0.5
                                    });
                                } else {
                                    p.payload = 'clean';
                                    p.color = '#4f4';
                                }
                            }

                            if (!blocked) {
                                const targetIdx = Math.floor(Math.random() * 3);
                                p.targetLLMIndex = targetIdx;
                                const targetY = llmYs[targetIdx];

                                const distRemaining = Math.abs(xLLM - xGuard);
                                const timeRemaining = distRemaining / Math.abs(p.vx);

                                if (timeRemaining > 0) {
                                    p.vy = (targetY - p.y) / timeRemaining;
                                }
                            }
                        }

                        if (p.x <= xLLM) {
                            p.state = 'dead';

                            let isMalice = (p.payload === 'poison');
                            let responseColor = isMalice ? '#b0f' : '#fff';

                            const hitY = (p.targetLLMIndex >= 0) ? llmYs[p.targetLLMIndex] : cy;

                            effects.push({
                                type: 'FLASH',
                                x: xLLM,
                                y: hitY,
                                color: responseColor,
                                life: 0.3
                            });

                            const distToGuard = xGuard - xLLM;
                            const timeToGuard = distToGuard / refSpeed;

                            let vyToGuard = 0;
                            if (timeToGuard > 0) {
                                vyToGuard = (cy - hitY) / timeToGuard;
                            }

                            particles.push({
                                id: Math.random(),
                                x: xLLM,
                                y: hitY,
                                type: 'response',
                                payload: isMalice ? 'malice' : 'clean',
                                color: responseColor,
                                size: 6,
                                vx: refSpeed,
                                vy: vyToGuard,
                                state: 'alive'
                            });
                        }
                    }
                    else if (p.vx > 0) {
                         if (p.x >= xGuard) {
                             if (p.vy !== 0) {
                                 p.x = xGuard;
                                 p.y = cy;
                                 p.vy = 0;
                             } else {
                                 p.y = cy;
                             }
                         }

                         if (p.x >= xEnv) {
                            p.state = 'dead';

                            if (p.payload === 'malice') {
                                effects.push({
                                    type: 'BREACH',
                                    x: xEnv,
                                    y: cy,
                                    life: 2.0
                                });
                            }
                         }
                    }

                    if (p.state === 'alive') {
                        flowCtx.fillStyle = p.color;
                        flowCtx.beginPath();
                        flowCtx.moveTo(p.x, p.y - p.size);
                        flowCtx.lineTo(p.x + p.size, p.y);
                        flowCtx.lineTo(p.x, p.y + p.size);
                        flowCtx.lineTo(p.x - p.size, p.y);
                        flowCtx.fill();
                    }
                });

                effects.forEach(e => {
                    e.life -= dt;
                    if (e.type === 'BLOCK' || e.type === 'BREACH') {
                        e.y -= 20 * dt;
                    }
                });
                effects = effects.filter(e => e.life > 0);

                effects.forEach(e => {
                    const maxLife = e.type === 'BREACH' ? 2.0 : 0.5;
                    const alpha = Math.max(0, e.life / maxLife);
                    flowCtx.save();
                    flowCtx.globalAlpha = alpha;

                    if (e.type === 'BLOCK') {
                        flowCtx.fillStyle = 'rgba(255, 0, 0, 0.5)';
                        flowCtx.beginPath();
                        flowCtx.arc(e.x, e.y, 20, 0, Math.PI*2);
                        flowCtx.fill();
                        flowCtx.fillStyle = '#f00';
                        flowCtx.textAlign = 'center';
                        flowCtx.font = '10px monospace';
                        flowCtx.fillText('BLOCKED', e.x, e.y - 25);
                    }
                    else if (e.type === 'FLASH') {
                        flowCtx.fillStyle = e.color;
                        flowCtx.fillRect(e.x - cw/2, e.y - cw/2, cw, cw);
                    }
                    else if (e.type === 'BREACH') {
                        flowCtx.fillStyle = 'rgba(255, 50, 255, 0.6)';
                        flowCtx.beginPath();
                        flowCtx.arc(e.x, e.y, 34, 0, Math.PI*2);
                        flowCtx.fill();
                        flowCtx.fillStyle = '#ff66ff';
                        flowCtx.textAlign = 'center';
                        flowCtx.font = 'bold 12px monospace';
                        flowCtx.fillText('!! BREACH !!', e.x, e.y - 40);
                    }

                    flowCtx.restore();
                });

                particles = particles.filter(p => p.state === 'alive');

                requestAnimationFrame(update);
            }
            requestAnimationFrame(update);
        }

        startFlowAnimation();

        function startModularViz() {
            const guardsEl = document.getElementById('modular-guards');
            const yamlEl = document.getElementById('modular-yaml-body');
            const tabsEl = document.getElementById('modular-tabs');
            const descEl = document.getElementById('modular-preset-desc');
            if (!guardsEl || !yamlEl) return;

            const CYCLE_MS = 6000;

            const allGuards = {
                secrets:    { name: 'Secrets Detection',  type: 'keyword_filter',       color: '#ff8a65', comment: ' # secrets' },
                pii:        { name: 'PII Filter',         type: 'pii_filter',           color: '#4fc3f7', comment: '' },
                content:    { name: 'Content Filter',     type: 'content_filter',       color: '#81c784', comment: '' },
                maxTokens:  { name: 'Max Tokens',         type: 'max_tokens',           color: '#fff176', comment: '' },
                inspection: { name: 'Input Inspection',   type: 'llm_input_inspection', color: '#ce93d8', comment: '' },
                commands:   { name: 'Command Blocking',   type: 'keyword_filter',       color: '#ef9a9a', comment: ' # commands' },
            };

            const presets = [
                { name: 'full',    desc: 'All guards active — maximum protection for production.',              guards: ['secrets', 'pii', 'content', 'maxTokens', 'inspection'] },
                { name: 'agentic', desc: 'Tailored for coding agents — blocks secrets, PII, and injections.',   guards: ['secrets', 'pii', 'commands', 'inspection'] },
                { name: 'minimal', desc: 'Lightweight — content filtering and token limits only.',              guards: ['content', 'maxTokens'] },
                { name: 'custom',  desc: 'Mix and match — pick exactly the guards your app needs.',             guards: ['pii', 'content', 'inspection'] },
            ];

            // Build named tabs
            presets.forEach((p, i) => {
                const tab = document.createElement('div');
                tab.className = 'modular-tab';
                tab.textContent = p.name;
                const bar = document.createElement('div');
                bar.className = 'modular-tab-progress';
                tab.appendChild(bar);
                tab.addEventListener('click', () => goTo(i));
                tabsEl.appendChild(tab);
            });

            let currentIndex = 0;
            let prevGuardIds = [];
            let intervalId = null;

            function makeGuardCard(id) {
                const g = allGuards[id];
                const card = document.createElement('div');
                card.className = 'modular-guard';
                card.dataset.guardId = id;
                card.style.setProperty('--guard-color', g.color);
                card.innerHTML = '<div class="modular-guard-dot"></div>'
                    + '<span class="modular-guard-name">' + g.name + '</span>'
                    + '<span class="modular-guard-type">' + g.type + '</span>';
                return card;
            }

            function makeYamlLine(id) {
                const g = allGuards[id];
                const line = document.createElement('div');
                line.className = 'yaml-line';
                line.dataset.guardId = id;
                line.innerHTML = '  <span class="t-dim">- type:</span> '
                    + '<span style="color:' + g.color + '">' + g.type + '</span>'
                    + (g.comment ? '<span class="t-dim">' + g.comment + '</span>' : '');
                return line;
            }

            function renderPreset(idx) {
                const preset = presets[idx];
                const newIds = preset.guards;
                const kept = newIds.filter(id => prevGuardIds.includes(id));
                const added = newIds.filter(id => !prevGuardIds.includes(id));
                const removed = prevGuardIds.filter(id => !newIds.includes(id));

                // Update tabs
                tabsEl.querySelectorAll('.modular-tab').forEach((t, j) => {
                    t.classList.toggle('active', j === idx);
                    // Reset progress bar on all tabs
                    const bar = t.querySelector('.modular-tab-progress');
                    bar.style.transition = 'none';
                    bar.style.width = '0%';
                    if (j === idx) {
                        void bar.offsetWidth;
                        bar.style.transition = 'width ' + (CYCLE_MS / 1000) + 's linear';
                        bar.style.width = '100%';
                    }
                });

                // Update description
                descEl.textContent = preset.desc;

                // --- Guard cards: diff-based ---

                // 1. Mark removed guards for exit
                removed.forEach(id => {
                    const el = guardsEl.querySelector('[data-guard-id="' + id + '"]');
                    if (el) {
                        el.classList.remove('visible');
                        el.classList.add('exiting');
                    }
                });

                // 2. Mark removed yaml lines for exit
                removed.forEach(id => {
                    const el = yamlEl.querySelector('[data-guard-id="' + id + '"]');
                    if (el) el.classList.remove('visible');
                });

                // 3. After exit animation, rebuild in correct order
                setTimeout(() => {
                    guardsEl.innerHTML = '';
                    yamlEl.innerHTML = '';

                    // YAML header
                    const header = document.createElement('div');
                    header.className = 'yaml-line visible';
                    header.innerHTML = '<span class="t-dim">apply:</span>';
                    yamlEl.appendChild(header);

                    newIds.forEach((id, i) => {
                        const isKept = kept.includes(id);
                        const delay = isKept ? 0 : (40 + added.indexOf(id) * 70);

                        // Guard card
                        const card = makeGuardCard(id);
                        if (isKept) {
                            card.classList.add('kept', 'visible');
                            // Pulse to show "still here"
                            requestAnimationFrame(() => card.classList.add('pulse'));
                            card.addEventListener('animationend', () => card.classList.remove('pulse'), { once: true });
                        }
                        guardsEl.appendChild(card);
                        if (!isKept) setTimeout(() => card.classList.add('visible'), delay);

                        // YAML line
                        const line = makeYamlLine(id);
                        if (isKept) line.classList.add('visible');
                        yamlEl.appendChild(line);
                        if (!isKept) setTimeout(() => line.classList.add('visible'), delay + 40);
                    });
                }, 220);

                prevGuardIds = [...newIds];
            }

            function advance() {
                renderPreset(currentIndex);
                currentIndex = (currentIndex + 1) % presets.length;
            }

            function goTo(idx) {
                currentIndex = idx;
                advance();
                resetTimer();
            }

            function resetTimer() {
                clearInterval(intervalId);
                intervalId = setInterval(advance, CYCLE_MS);
            }

            advance();
            resetTimer();
        }

        startModularViz();

        function startFontToggle() {
            const fonts = [
                'var(--font-pixel-circle)',
                'var(--font-pixel-grid)',
                'var(--font-pixel-line)',
                'var(--font-pixel-square)',
                'var(--font-pixel-triangle)'
            ];

            const applyPerLetterFontToggle = (element) => {
                if (!element) return;

                const text = element.textContent || '';
                const characters = Array.from(text);

                element.textContent = '';

                const glyphs = characters.map((character) => {
                    const span = document.createElement('span');
                    span.textContent = character === ' ' ? '\u00A0' : character;
                    span.style.display = 'inline-block';
                    element.appendChild(span);
                    return span;
                });

                glyphs.forEach((glyph, glyphIndex) => {
                    let fontIndex = glyphIndex % fonts.length;
                    glyph.style.fontFamily = fonts[fontIndex];

                    setInterval(() => {
                        const step = 1 + Math.floor(Math.random() * 2);
                        fontIndex = (fontIndex + step) % fonts.length;
                        glyph.style.fontFamily = fonts[fontIndex];
                    }, 1000);
                });
            };

            applyPerLetterFontToggle(document.querySelector('#site-footer'));
        }

        startFontToggle();

        // Scroll-reveal for feature panels
        const featureObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    entry.target.classList.add('visible');
                    featureObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });

        document.querySelectorAll('.feature-panel').forEach(panel => {
            featureObserver.observe(panel);
        });

        // Scroll-reveal for agent cards (staggered)
        const agentObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const cards = entry.target.querySelectorAll('.agent-card');
                    cards.forEach((card, i) => {
                        setTimeout(() => card.classList.add('visible'), i * 80);
                    });
                    agentObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.15 });
        const agentsGrid = document.querySelector('.agents-grid');
        if (agentsGrid) agentObserver.observe(agentsGrid);

        // Scroll-reveal for FAQ items (staggered)
        const faqObserver = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) {
                    const items = entry.target.querySelectorAll('.faq-item');
                    items.forEach((item, i) => {
                        setTimeout(() => item.classList.add('visible'), i * 100);
                    });
                    faqObserver.unobserve(entry.target);
                }
            });
        }, { threshold: 0.1 });
        const faqList = document.querySelector('.faq-list');
        if (faqList) faqObserver.observe(faqList);
    </script>
</body>
</html>
