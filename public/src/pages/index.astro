    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            "name": "OpenGuard",
            "description": "OpenGuard is a local LLM security gateway for coding agents. Block prompt injection, redact PII, inspect traffic, and enforce policy with a drop-in proxy.",
            "applicationCategory": "SecurityApplication",
            "url": "https://openguard.sh/",
            "operatingSystem": "Linux, macOS, Windows, Docker",
            "codeRepository": "https://github.com/Jitera-Labs/openguard",
            "softwareVersion": "0.1",
            "screenshot": "https://openguard.sh/splash.png",
            "featureList": [
                "PII redaction (email, phone, SSN, credit card)",
                "Prompt injection detection",
                "Keyword blocking and sanitization",
                "Token usage capping",
                "LLM-powered semantic input inspection",
                "Content filtering",
                "Streaming response support",
                "OpenAI and Anthropic API compatibility",
                "YAML-based policy configuration",
                "Zero telemetry"
            ],
            "offers": {
                "@type": "Offer",
                "price": "0",
                "priceCurrency": "USD"
            },
            "publisher": {
                "@type": "Organization",
                "name": "Jitera Labs",
                "url": "https://jitera.com/"
            }
        }
    </script>
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "FAQPage",
            "mainEntity": [
                {
                    "@type": "Question",
                    "name": "Does OpenGuard add latency?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Guards run on input before forwarding to the provider. Regex-based guards add negligible overhead. The llm_input_inspection guard adds a full LLM round-trip since it sends the prompt to an inspection model first."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Does OpenGuard work with streaming?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. Guards evaluate the input before the request is forwarded. The streaming response from the provider is proxied straight through to your client."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Does OpenGuard collect telemetry?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "No. OpenGuard only connects to the LLM providers you explicitly configure. Nothing phones home."
                    }
                },
                {
                    "@type": "Question",
                    "name": "What LLM providers work with OpenGuard?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Any provider exposing /v1/chat/completions (OpenAI-compatible) or /v1/messages (Anthropic-compatible). OpenRouter, Azure OpenAI, local models via Ollama — anything behind those endpoints."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Does OpenGuard work with LangChain or LlamaIndex?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. Any library that lets you set a custom base URL works — LangChain, LlamaIndex, LiteLLM, and others. Point the base URL at http://localhost:23294/v1 and your real provider API key, and all traffic flows through the guard pipeline."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Can I run OpenGuard in production or CI?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. The Docker image is the recommended path for production and CI — no Python host dependency, single container, configurable via environment variables. Mount your guards.yaml and pass provider keys with -e."
                    }
                },
                {
                    "@type": "Question",
                    "name": "How do I block a specific keyword or secret?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Use the keyword_filter guard. Add the keyword or regex pattern to the keywords list in guards.yaml and set the action to block or redact. It matches across request and response content, including streamed output."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Does OpenGuard support local models like Ollama?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. Any model server that exposes an OpenAI-compatible endpoint (/v1/chat/completions) works — Ollama, LM Studio, vLLM, and others. No API key is required for local models."
                    }
                },
                {
                    "@type": "Question",
                    "name": "Is OpenGuard open source?",
                    "acceptedAnswer": {
                        "@type": "Answer",
                        "text": "Yes. OpenGuard is MIT-licensed and available on GitHub at https://github.com/Jitera-Labs/openguard. Contributions, issues, and feature requests are welcome."
                    }
                }
            ]
        }
    </script>
    <script type="application/ld+json">
        {
            "@context": "https://schema.org",
            "@type": "WebSite",
            "name": "OpenGuard",
            "url": "https://openguard.sh/"
        }
    </script>
